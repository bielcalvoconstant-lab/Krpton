<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Krypton | Configurações</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0b0f19] text-[#e2e8f0] min-h-screen font-sans antialiased selection:bg-violet-500/30">

  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 mb-10 border-b border-[#1e293b]/60 pb-6">
      <div class="flex items-center gap-5">
        <% if (guild.icon) { %>
          <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="w-14 h-14 rounded-2xl border border-[#1e293b] shadow-xl" />
        <% } else { %>
          <div class="w-14 h-14 rounded-2xl bg-[#1e293b] flex items-center justify-center font-extrabold text-violet-400 text-lg shadow-inner"><%= guild.name[0] %></div>
        <% } %>
        <div>
          <h1 class="text-2xl font-black tracking-tight text-white"><%= guild.name %></h1>
          <p class="text-xs text-[#94a3b8] mt-1">Configure e sincronize os tickets do bot no seu servidor Discord</p>
        </div>
      </div>
      <a href="/dashboard" class="bg-[#1e293b]/80 hover:bg-[#334155]/85 text-xs text-[#cbd5e1] font-semibold py-3 px-5 rounded-xl border border-[#334155]/60 transition-all shadow-md">
        &larr; Voltar para a lista
      </a>
    </div>

    <!-- Alerta de Sucesso -->
    <% if (typeof query !== 'undefined' && query.success) { %>
      <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-5 py-4 rounded-xl mb-8 text-sm shadow flex items-center gap-2">
        <span class="text-emerald-500">✔</span> Configurações salvas e aplicadas no Discord em tempo real!
      </div>
    <% } %>

    <!-- Form & Preview Container -->
    <form action="/dashboard/<%= guild.id %>/save" method="POST" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Coluna de Configurações -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Bloco 1: Estrutura de Canais -->
        <div class="bg-[#111827]/60 p-6 rounded-2xl border border-[#1e293b]/80 shadow-lg space-y-5">
          <h2 class="text-base font-bold text-white flex items-center gap-2">
            📂 Estrutura de Canais
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Categoria dos Tickets</label>
              <select name="ticketCategory" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-xs text-slate-200 outline-none">
                <option value="">Nenhuma Categoria</option>
                <% channels.filter(c => c.type === 4).forEach(ch => { %>
                  <option value="<%= ch.id %>" <%= config.ticketCategory === ch.id ? 'selected' : '' %>><%= ch.name %></option>
                <% }) %>
              </select>
            </div>

            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Canal de Transcripts</label>
              <select name="transcriptChannelId" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-xs text-slate-200 outline-none">
                <option value="">Sem Canal Definido</option>
                <% channels.filter(c => c.type === 0).forEach(ch => { %>
                  <option value="<%= ch.id %>" <%= config.transcriptChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Canal de Log de Atividade</label>
            <select name="logChannelId" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-xs text-slate-200 outline-none">
              <option value="">Sem Canal Definido</option>
              <% channels.filter(c => c.type === 0).forEach(ch => { %>
                <option value="<%= ch.id %>" <%= config.logChannelId === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <!-- Bloco 2: Status do Sistema & Cargos Staff -->
        <div class="bg-[#111827]/60 p-6 rounded-2xl border border-[#1e293b]/80 shadow-lg space-y-5">
          <h2 class="text-base font-bold text-white flex items-center gap-2">
            🛡️ Ativação & Equipe de Atendimento
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Status do Sistema de Tickets</label>
              <select name="active" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-xs text-slate-200 outline-none">
                <option value="true" <%= config.active !== false ? 'selected' : '' %>>🟢 Ativado (Permite abertura)</option>
                <option value="false" <%= config.active === false ? 'selected' : '' %>>🔴 Desativado (Bloqueia novos tickets)</option>
              </select>
            </div>

            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Cargos da Equipe / Staff (Selecione vários)</label>
              <div class="space-y-2 max-h-36 overflow-y-auto bg-[#030712] p-3 rounded-xl border border-[#1e293b]">
                <% roles.forEach(role => { %>
                  <label class="flex items-center gap-2.5 cursor-pointer hover:bg-[#111827] p-1 rounded transition text-[11px]">
                    <input type="checkbox" name="staffRoleIds" value="<%= role.id %>" <%= config.staffRoleIds && config.staffRoleIds.includes(role.id) ? 'checked' : '' %> class="rounded border-[#1e293b] text-violet-600 focus:ring-violet-500 bg-transparent" />
                    <span class="text-[#cbd5e1] truncate"><%= role.name %></span>
                  </label>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

        <!-- Bloco 3: Edição Dinâmica & Opção Mostrar/Ocultar de Categorias -->
        <div class="bg-[#111827]/60 p-6 rounded-2xl border border-[#1e293b]/80 shadow-lg space-y-5">
          <div class="flex justify-between items-center border-b border-[#1e293b]/40 pb-3">
            <h2 class="text-base font-bold text-white flex items-center gap-2">
              🏷️ Editar Categorias de Suporte
            </h2>
            <button type="button" onclick="addCategoryRow()" class="bg-violet-600 hover:bg-violet-500 text-white text-xs font-bold py-2 px-4 rounded-xl transition shadow shadow-violet-600/10">
              + Adicionar
            </button>
          </div>
          
          <div id="categories-container" class="space-y-4">
            <% config.categories.forEach((cat, index) => { %>
              <div class="category-row bg-[#030712]/50 p-5 rounded-2xl border border-[#1e293b]/50 relative space-y-3 shadow-inner" id="cat-row-<%= index %>">
                <button type="button" onclick="removeCategoryRow(<%= index %>)" class="absolute top-3 right-4 text-red-400 hover:text-red-300 text-xs font-bold transition">Excluir</button>
                
                <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
                  <div class="md:col-span-2">
                    <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Nome da Categoria</label>
                    <input type="text" name="catLabel[]" value="<%= cat.label %>" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500" required />
                  </div>
                  <div>
                    <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Emoji</label>
                    <input type="text" name="catEmoji[]" value="<%= cat.emoji %>" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none text-center focus:border-violet-500" required />
                  </div>
                  <!-- MOSTRAR / OCULTAR INTERATIVO -->
                  <div>
                    <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Exibição</label>
                    <select name="catStatus[]" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500">
                      <option value="show" <%= cat.active !== false ? 'selected' : '' %>>🟢 Exibir</option>
                      <option value="hide" <%= cat.active === false ? 'selected' : '' %>>🔴 Ocultar</option>
                    </select>
                  </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Descrição</label>
                    <input type="text" name="catDesc[]" value="<%= cat.description %>" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500" />
                  </div>
                  <div>
                    <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Chave / ID Interno</label>
                    <input type="text" name="catValue[]" value="<%= cat.value %>" class="w-full bg-[#030712]/60 p-2.5 rounded-xl border border-[#1e293b]/40 text-xs text-slate-500 outline-none cursor-not-allowed" readonly />
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Bloco 4: Design e Imagens do Painel -->
        <div class="bg-[#111827]/60 p-6 rounded-2xl border border-[#1e293b]/80 shadow-lg space-y-5">
          <h2 class="text-base font-bold text-white flex items-center gap-2">
            🎨 Design & Conteúdo do Painel
          </h2>
          <div class="space-y-4">
            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Título do Painel de Suporte</label>
              <input type="text" id="titleInput" name="title" value="<%= config.panelEmbed.title %>" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-sm text-slate-200 outline-none" required />
            </div>
            
            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Descrição / Mensagem</label>
              <textarea id="descInput" name="description" rows="4" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-all text-sm text-slate-200 outline-none resize-none" required><%= config.panelEmbed.description %></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">URL da Miniatura (Thumbnail)</label>
                <input type="url" id="thumbnailInput" name="thumbnail" value="<%= config.panelEmbed.thumbnail || '' %>" placeholder="Ex: https://dominio.com/logo.png" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 transition-all text-sm text-slate-200 outline-none" />
              </div>

              <div>
                <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">URL do Banner / Imagem Principal</label>
                <input type="url" id="imageInput" name="image" value="<%= config.panelEmbed.image || '' %>" placeholder="Ex: https://dominio.com/banner.png" class="w-full bg-[#030712] p-3 rounded-xl border border-[#1e293b] focus:border-violet-500 transition-all text-sm text-slate-200 outline-none" />
              </div>
            </div>

            <div>
              <label class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider mb-2">Cor da Borda Lateral</label>
              <div class="flex items-center gap-3">
                <input type="color" id="colorInput" name="color" value="<%= config.panelEmbed.color %>" class="w-14 h-11 bg-transparent cursor-pointer rounded-lg border-none" />
                <span class="text-xs text-[#64748b]">Selecione uma cor de realce da janela de suporte</span>
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-4 rounded-xl transition-all text-xs shadow-lg shadow-violet-600/20 tracking-wider uppercase">
          Salvar Todas as Configurações e Atualizar Discord
        </button>
      </div>

      <!-- Coluna de Prévia Visual -->
      <div class="lg:col-span-5">
        <div class="sticky top-8 space-y-4">
          <span class="block text-[10px] font-black text-[#64748b] uppercase tracking-wider">Simulação do Painel no Discord</span>
          
          <!-- Mockup Discord Message -->
          <div class="bg-[#313338] p-4 rounded-xl shadow-xl border border-[#1e293b]/40 flex gap-4 text-sm font-sans">
            <div class="w-10 h-10 rounded-full bg-violet-600 flex-shrink-0 flex items-center justify-center font-bold text-white text-base">
              K
            </div>
            <div class="space-y-2 w-full overflow-hidden">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-white">Krypton</span>
                <span class="bg-[#5865F2] text-white text-[10px] font-bold px-1.5 py-0.5 rounded">BOT</span>
                <span class="text-xs text-[#949ba4]">Hoje às 12:00</span>
              </div>
              
              <!-- Embed Box -->
              <div id="previewCard" class="bg-[#2b2d31] p-4 rounded-md border-l-4 border-violet-500 max-w-full space-y-3 relative">
                <div class="flex justify-between items-start gap-4">
                  <div id="previewTitle" class="font-bold text-white text-sm md:text-base break-all pr-4">
                    <%= config.panelEmbed.title %>
                  </div>
                  <img id="previewThumbnail" src="<%= config.panelEmbed.thumbnail || '' %>" class="w-12 h-12 rounded object-cover flex-shrink-0 <%= config.panelEmbed.thumbnail ? '' : 'hidden' %>" />
                </div>
                <div id="previewDesc" class="text-[#dbdee1] text-xs leading-relaxed whitespace-pre-wrap">
                  <%= config.panelEmbed.description %>
                </div>
                <img id="previewImage" src="<%= config.panelEmbed.image || '' %>" class="w-full rounded mt-2 object-cover max-h-40 <%= config.panelEmbed.image ? '' : 'hidden' %>" />
              </div>

              <!-- Button/Select Mockup -->
              <div class="bg-[#1e1f22] p-3.5 rounded border border-[#3f4147] flex justify-between items-center max-w-full">
                <span class="text-[#949ba4] text-xs">Selecione uma categoria para suporte...</span>
                <span class="text-[#949ba4] text-xs">&darr;</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </form>
  </div>

  <script>
    const titleInput = document.getElementById('titleInput');
    const descInput = document.getElementById('descInput');
    const colorInput = document.getElementById('colorInput');
    const thumbnailInput = document.getElementById('thumbnailInput');
    const imageInput = document.getElementById('imageInput');
    
    const previewTitle = document.getElementById('previewTitle');
    const previewDesc = document.getElementById('previewDesc');
    const previewCard = document.getElementById('previewCard');
    const previewThumbnail = document.getElementById('previewThumbnail');
    const previewImage = document.getElementById('previewImage');

    function updatePreview() {
      previewTitle.innerText = titleInput.value || 'Mensagem do Sistema';
      previewDesc.innerText = descInput.value || 'Por favor, selecione uma opção abaixo para falar com um moderador.';
      previewCard.style.borderColor = colorInput.value;

      if (thumbnailInput.value && thumbnailInput.value.trim() !== '') {
        previewThumbnail.src = thumbnailInput.value;
        previewThumbnail.classList.remove('hidden');
      } else {
        previewThumbnail.classList.add('hidden');
      }

      if (imageInput.value && imageInput.value.trim() !== '') {
        previewImage.src = imageInput.value;
        previewImage.classList.remove('hidden');
      } else {
        previewImage.classList.add('hidden');
      }
    }

    // Código de Manipulação Dinâmica de Adição e Remoção de Categorias
    let catCounter = <%= config.categories.length %>;
    
    function removeCategoryRow(index) {
      const row = document.getElementById('cat-row-' + index);
      if (row) {
        row.remove();
      }
    }

    function addCategoryRow() {
      const container = document.getElementById('categories-container');
      const randomId = Math.random().toString(36).substring(7);
      const newRow = document.createElement('div');
      newRow.className = "category-row bg-[#030712]/50 p-5 rounded-2xl border border-[#1e293b]/50 relative space-y-3 shadow-inner";
      newRow.id = 'cat-row-' + catCounter;
      newRow.innerHTML = `
        <button type="button" onclick="removeCategoryRow(${catCounter})" class="absolute top-3 right-4 text-red-400 hover:text-red-300 text-xs font-bold transition">Excluir</button>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
          <div class="md:col-span-2">
            <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Nome da Categoria</label>
            <input type="text" name="catLabel[]" placeholder="Ex: Suporte Geral" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500" required />
          </div>
          <div>
            <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Emoji</label>
            <input type="text" name="catEmoji[]" placeholder="💬" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none text-center focus:border-violet-500" required />
          </div>
          <div>
            <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Exibição</label>
            <select name="catStatus[]" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500">
              <option value="show" selected>🟢 Exibir</option>
              <option value="hide">🔴 Ocultar</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div>
            <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Descrição</label>
            <input type="text" name="catDesc[]" placeholder="Fale com a nossa staff" class="w-full bg-[#030712] p-2.5 rounded-xl border border-[#1e293b] text-xs text-slate-200 outline-none focus:border-violet-500" />
          </div>
          <div>
            <label class="block text-[9px] font-black text-[#64748b] uppercase tracking-wider mb-1">Chave / ID do Botão</label>
            <input type="text" name="catValue[]" value="categoria_${randomId}" class="w-full bg-[#030712]/60 p-2.5 rounded-xl border border-[#1e293b]/40 text-xs text-slate-500 outline-none cursor-not-allowed" readonly />
          </div>
        </div>
      `;
      container.appendChild(newRow);
      catCounter++;
    }

    titleInput.addEventListener('input', updatePreview);
    descInput.addEventListener('input', updatePreview);
    colorInput.addEventListener('input', updatePreview);
    thumbnailInput.addEventListener('input', updatePreview);
    imageInput.addEventListener('input', updatePreview);
    
    updatePreview();
  </script>
</body>
</html>

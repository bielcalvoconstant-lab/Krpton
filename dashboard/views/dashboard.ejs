<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Krypton | Meus Servidores</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0b0f19] text-slate-100 min-h-screen font-sans">

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-10 pb-6 border-b border-slate-800">
      <div class="flex items-center gap-4">
        <% if (user.avatar) { %>
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-12 h-12 rounded-full border border-violet-500/30" />
        <% } else { %>
          <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center font-bold">U</div>
        <% } %>
        <div>
          <div class="flex items-center gap-2">
            <h1 class="text-2xl font-bold tracking-tight">Olá, <%= user.username %></h1>
            <% if (role === 'superadmin') { %>
              <span class="bg-violet-500/10 text-violet-400 border border-violet-500/30 text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full">Developer Master</span>
            <% } %>
          </div>
          <p class="text-xs text-slate-400">Escolha um servidor para gerenciar as configurações</p>
        </div>
      </div>
      <div class="flex gap-3">
        <% if (role === 'superadmin') { %>
          <!-- BOTÃO EXCLUSIVO DE ACESSO À PÁGINA DE CONTROLE DO BOT -->
          <a href="/dashboard/bot/admin" class="bg-violet-600 hover:bg-violet-500 text-white font-bold py-2.5 px-4 rounded-xl border border-violet-500/20 text-xs tracking-wider uppercase transition-all shadow">
            ⚙️ Configuração do Bot
          </a>
        <% } %>
        <a href="/" class="bg-slate-800 hover:bg-slate-700 text-xs font-semibold py-2.5 px-4 rounded-xl transition-all">Página Inicial</a>
        <a href="/auth/logout" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-semibold py-2.5 px-4 rounded-xl border border-red-500/20 transition-all">Desconectar</a>
      </div>
    </header>

    <!-- Alerta de Assinatura -->
    <% if (typeof query !== 'undefined' && query.checkout_success) { %>
      <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 px-5 py-4 rounded-xl mb-8 text-sm shadow">
        ⭐ Parabéns! Sua assinatura **VIP** foi ativada com sucesso pelo Stripe. Seus comandos de música no bot estão desbloqueados!
      </div>
    <% } %>

    <!-- Lista de Servidores -->
    <main>
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-lg font-bold text-slate-400 uppercase tracking-wider">Seus Servidores com Administração</h2>
        <% if (!isVip && role !== 'superadmin') { %>
          <!-- BOTÃO DE ASSINATURA REAL DO STRIPE -->
          <a href="/stripe/checkout" class="bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-slate-950 font-bold py-2 px-4 rounded-xl text-xs tracking-wider uppercase transition-all shadow-md">
            ⭐ Assinar VIP (Músicas)
          </a>
        <% } else { %>
          <span class="bg-amber-500/10 text-amber-500 border border-amber-500/30 text-xs font-black uppercase tracking-widest px-3 py-1.5 rounded-full">VIP Ativo</span>
        <% } %>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% guilds.forEach(g => { %>
          <div class="bg-[#111827]/60 p-6 rounded-2xl flex flex-col justify-between border border-[#1e293b]/80 shadow-lg hover:border-violet-500/40 hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex items-center gap-4 mb-6">
              <% if (g.icon) { %>
                <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" class="w-16 h-16 rounded-2xl" />
              <% } else { %>
                <div class="w-16 h-16 rounded-2xl bg-slate-800 flex items-center justify-center font-extrabold text-xl text-violet-400"><%= g.name[0] %></div>
              <% } %>
              <div class="overflow-hidden">
                <h3 class="font-bold text-lg truncate text-slate-100"><%= g.name %></h3>
                <p class="text-xs text-slate-500 truncate">ID: <%= g.id %></p>
              </div>
            </div>
            
            <a href="/dashboard/<%= g.id %>" class="w-full text-center bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 px-4 rounded-xl transition-all text-sm shadow-md">
              Configurar Painel
            </a>
          </div>
        <% }) %>
      </div>
    </main>
  </div>

</body>
</html>
